{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["vite/client"],
    "paths": {
      "@milkybytes/image-dropzone": ["../src/index.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.ts", "../src/declarations.d.ts"],
  "exclude": ["node_modules"]
}
